rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Datos por usuario: solo el propio usuario puede leer/escribir
    match /usuarios/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Stats globales: todos los usuarios autenticados pueden escribir (incrementos al guardar viaje)
    // Solo el admin puede leer directamente (el panel admin usa onSnapshot)
    match /stats/{document} {
      allow read: if request.auth != null && request.auth.token.email == 'alangambacorta7@gmail.com';
      allow write: if request.auth != null;
    }

    // Config global (sponsors, etc): todos pueden leer, solo admin puede escribir
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'alangambacorta7@gmail.com';
    }
  }
}
