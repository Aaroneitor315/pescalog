rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'alangambacorta7@gmail.com';
    }

    // Datos por usuario: el propio usuario o el admin pueden leer
    match /usuarios/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Stats globales: todos los autenticados pueden escribir, solo admin lee
    match /stats/{document} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    // Config global: todos pueden leer, solo admin escribe
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
